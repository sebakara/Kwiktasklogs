# Employee uploads: ignore files in upload dirs; tracked .gitkeep keeps paths (parent `dir/*` needs `!dir/sub/` so nested .gitkeep stays tracked)
/public/employees/documents/*
!/public/employees/documents/.gitkeep
!/public/employees/documents/original/
!/public/employees/documents/signed/
/public/employees/documents/original/*
!/public/employees/documents/original/.gitkeep
/public/employees/documents/signed/*
!/public/employees/documents/signed/.gitkeep
/public/employees/onboarding/*
!/public/employees/onboarding/.gitkeep
!/public/employees/onboarding/passport/
!/public/employees/onboarding/nid/
/public/employees/onboarding/passport/*
!/public/employees/onboarding/passport/.gitkeep
/public/employees/onboarding/nid/*
!/public/employees/onboarding/nid/.gitkeep
/public/employees/avatar/*
!/public/employees/avatar/.gitkeep
/public/employees/nid/*
!/public/employees/nid/.gitkeep
/public/employees/passport/*
!/public/employees/passport/.gitkeep
/public/employees/work-permit/*
!/public/employees/work-permit/.gitkeep
/public/employees/reviews/*
!/public/employees/reviews/.gitkeep
/public/employees/skills/*
!/public/employees/skills/.gitkeep
